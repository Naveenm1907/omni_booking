rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only services list for the assignment demo.
    match /services/{serviceId} {
      allow read: if true;
      // Lock down writes by default.
      allow write: if false;
    }

    // Bookings: allow create for demo purposes with basic shape validation.
    // NOTE: For a real product, add authentication and stricter rules.
    match /bookings/{bookingId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'startAt',
          'durationMinutes',
          'counterId',
          'serviceIds',
          'totalPriceCents'
        ]) &&
        request.resource.data.startAt is timestamp &&
        request.resource.data.durationMinutes is int &&
        request.resource.data.durationMinutes > 0 &&
        request.resource.data.counterId is int &&
        request.resource.data.counterId >= 0 &&
        request.resource.data.counterId < 3 &&
        request.resource.data.serviceIds is list &&
        request.resource.data.serviceIds.size() > 0 &&
        request.resource.data.totalPriceCents is int &&
        request.resource.data.totalPriceCents >= 0;

      // Disallow updates/deletes to keep the demo simple.
      allow update, delete: if false;
    }
  }
}

